# Data — never commit raw or processed files
data/raw/*
data/processed/*
data/features/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/features/.gitkeep

# Reports — keep dir, ignore generated files
reports/*
!reports/.gitkeep

